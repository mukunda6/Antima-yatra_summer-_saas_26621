rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.createdAt is timestamp;
    }

    function isValidRecord(data) {
      return data.ownerId == request.auth.uid &&
             data.deceasedName is string && data.deceasedName.size() > 0 && data.deceasedName.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidContact(data) {
      return data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidLog(data) {
      return data.ownerId == request.auth.uid &&
             data.message is string && data.message.size() > 0 &&
             data.timestamp is timestamp;
    }

    // --- Collection Routes ---

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().email == existing().email;
    }

    // Records collection
    match /records/{recordId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidRecord(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().ownerId == request.auth.uid &&
                      isValidRecord(incoming()) &&
                      incoming().ownerId == existing().ownerId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;
      allow delete: if isVerified() && existing().ownerId == request.auth.uid;
    }

    // Contacts collection
    match /contacts/{contactId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidContact(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().ownerId == request.auth.uid &&
                      isValidContact(incoming()) &&
                      incoming().ownerId == existing().ownerId &&
                      incoming().createdAt == existing().createdAt;
      allow delete: if isVerified() && existing().ownerId == request.auth.uid;
    }

    // Notification Logs
    match /notification_logs/{logId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidLog(incoming()) && incoming().timestamp == request.time;
    }
  }
}
